import joblib
from sklearn.ensemble import RandomForestRegressor
import pandas as pd

df = pd.read_csv("rocket_trajectory_data.csv")

X = df[['Time', 'Altitude', 'Velocity', 'Mass']]
y = df['Thrust']

model = RandomForestRegressor(n_estimators=200)
model.fit(X, y)

joblib.dump(model, "model_new.pkl")
print("Model saved!")